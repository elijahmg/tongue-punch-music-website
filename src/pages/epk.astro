---
import Layout from "../layouts/Layout.astro";
import Menu from "../components/Menu.astro";

import bandEpk from "../assets/band_epk.jpg";

import ady from "../assets/ady.jpg";
import eli from "../assets/eli.jpg";
import murat from "../assets/murat.jpg";
import kill from "../assets/kill.jpg";
---

<Layout
  title="Tongue Punch — EPK"
  description="Electronic Press Kit for Tongue Punch. Alt rock band from Prague."
>
  <Menu />

  <!-- Header -->
  <section class="relative pt-48 pb-32 px-4 md:px-12 overflow-hidden">
    <div
      class="absolute inset-0 pointer-events-none select-none opacity-5 overflow-hidden"
    >
      <div
        class="font-display text-[30vw] leading-none whitespace-nowrap animate-scroll-text"
      >
        EPK EPK EPK EPK EPK EPK EPK
      </div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto">
      <p class="text-brand-accent font-display text-xl tracking-[0.4em] mb-4">
        ELECTRONIC PRESS KIT
      </p>
      <h1 class="text-brand-white text-8xl md:text-[14rem] leading-[0.85]">
        TONGUE<br /><span class="text-brand-accent">PUNCH</span>
      </h1>
      <p
        class="text-brand-white/40 font-display text-xl md:text-2xl tracking-widest mt-8"
      >
        ALT ROCK — PRAGUE
      </p>
    </div>
  </section>

  <!-- Divider -->
  <div class="border-t border-brand-white/10 mx-4 md:mx-12"></div>

  <!-- Elevator pitch -->
  <section class="relative py-24 px-4 md:px-12 bg-brand-accent overflow-hidden">
    <div
      class="absolute inset-0 pointer-events-none select-none opacity-10 overflow-hidden"
    >
      <div
        class="font-display text-[40vw] leading-none whitespace-nowrap text-brand-black"
      >
        TONGUE PUNCH
      </div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto">
      <p
        class="font-display text-brand-black text-3xl md:text-5xl leading-tight max-w-4xl uppercase tracking-tight"
      >
        Four misfits. One stage. The loudest thing to come out of Prague since
        the revolution.
      </p>
    </div>
  </section>

  <!-- Divider -->
  <div class="border-t border-brand-white/10 mx-4 md:mx-12"></div>

  <!-- Short bio -->
  <section class="relative py-24 px-4 md:px-12">
    <div
      class="max-w-7xl mx-auto flex flex-col md:flex-row gap-12 md:gap-32 items-start"
    >
      <div class="md:w-1/4 shrink-0">
        <span class="text-brand-accent font-display text-sm tracking-[0.4em]"
          >SHORT BIO</span
        >
      </div>
      <p
        class="text-brand-white/80 text-xl md:text-2xl leading-relaxed max-w-3xl"
      >
        Tongue Punch is a Prague-based powerhouse defined by what they call
        "harmonising haymakers." Fronted by the charismatic Ady Ferguson, whose
        vocal range sets the group’s high-energy tone, the band bridges the gap
        between raw power and technical finesse. The sound is anchored by Ilya
        Fakhrutdinov’s versatile guitar work and the enigmatic percussive
        textures of Murat Yilmam, while Irish cellist Kilian McGrath weaves in
        the swathing melodies and deep undertones that make their lineup truly
        unique. After years of lighting up the Prague scene, Tongue Punch has
        refined a live show that is as atmospheric as it is emphatic.
      </p>
    </div>
  </section>

  <!-- Divider -->
  <div class="border-t border-brand-white/10 mx-4 md:mx-12"></div>

  <!-- Bio + Photos two-column grid -->
  <section class="relative py-32 px-4 md:px-12">
    <div
      class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 items-start"
    >
      <!-- Left: Paragraphs -->
      <div class="flex flex-col gap-10">
        <div>
          <h2 class="text-brand-white text-6xl md:text-8xl leading-none">
            BIO
          </h2>
          <span class="text-brand-accent font-display text-sm tracking-[0.4em]"
            >ABOUT THE BAND</span
          >
        </div>
        <div
          class="flex flex-col gap-4 text-brand-white/60 text-lg leading-relaxed"
        >
          <p>
            Tongue Punch is a high-octane collective of international "misfits"
            who turned a chance meeting into one of Prague’s most compelling
            live acts. Built on a foundation of emphatic vocals and "harmonising
            haymakers," the band has spent years refining a sound that defies
            easy categorization, blending technical precision with raw,
            unpredictable energy.
          </p>
          <span class="text-brand-accent font-display text-sm tracking-[0.4em]">
            The Lineup
          </span>
          <p>
            The group is led by Ady Ferguson, a veteran of the Central European
            music circuit for nearly two decades. Known for his world-class
            charisma and expansive vocal range, Ferguson provides the heartbeat
            for the band’s evolving sound. He is joined by:
          </p>

          <p>
            Ilya Fakhrutdinov: An experimental guitarist with a savant-like ear
            for texture and melody.
          </p>
          <p>
            Murat Yilman: An eccentric, highly adaptable percussionist who
            provides the band's driving, multi-ethnic rhythmic pulse.
          </p>
          <p>
            Kilian McGrath: A classically trained Irish cellist whose transition
            to electric cello provided the "final ingredient"—adding swathing
            melodies and cinematic grit to the mix.
          </p>

          <span class="text-brand-accent font-display text-sm tracking-[0.4em]">
            The Live Experience
          </span>
          <p>
            Tongue Punch is a band built for the stage. Their versatility allows
            them to pivot from intimate, dynamic showcases at legendary venues
            like Balbínka to "high-girth" stadium-style performances. For their
            larger-scale shows—including multiple sold-out nights at Vinohradský
            Pivovar—the core quartet is bolstered by a powerhouse session
            bassist and drummer, transforming the group into a relentless wall
            of sound. The Future With an accelerating output of new material and
            a reputation for "flawless interconnectivity," Tongue Punch is
            currently expanding their reach beyond Prague. Combining a loyal
            following with a fearless creative streak, they are moving toward
            larger international stages, proving that for a band this unique,
            there is no ceiling.
          </p>
        </div>
      </div>

      <!-- Right: Photos -->
      <div class="grid grid-cols-2 gap-4">
        <img
          src={bandEpk.src}
          class="col-span-2 bg-brand-white/5 border border-brand-white/10"
        />

        <img
          src={ady.src}
          class="bg-brand-white/5 border border-brand-white/10"
        />
        <img
          src={eli.src}
          class="bg-brand-white/5 border border-brand-white/10"
        />
        <img
          src={murat.src}
          class="bg-brand-white/5 border border-brand-white/10"
        />
        <img
          src={kill.src}
          class="bg-brand-white/5 border border-brand-white/10"
        />
      </div>
    </div>
  </section>
</Layout>

<!-- Divider -->
<div class="border-t border-brand-white/10 mx-4 md:mx-12"></div>

<!-- Music -->
<section class="relative py-32 px-4 md:px-12">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col gap-10 max-w-2xl mx-auto">
      <div>
        <h2 class="text-brand-white text-6xl md:text-8xl leading-none">
          MUSIC
        </h2>
        <span class="text-brand-accent font-display text-sm tracking-[0.4em]"
          >DISCOGRAPHY</span
        >
      </div>
      <div class="relative group">
        <div
          class="absolute -inset-4 border border-brand-white/20 translate-x-1 translate-y-1 group-hover:translate-x-0 group-hover:translate-y-0 transition-transform duration-500"
        >
        </div>
        <div
          class="absolute -inset-4 border border-brand-accent/40 -translate-x-1 -translate-y-1 group-hover:translate-x-0 group-hover:translate-y-0 transition-transform duration-500 delay-75"
        >
        </div>
        <div class="relative p-1">
          <iframe
            title="Tongue Punch on Spotify"
            style="border-radius:0"
            src="https://open.spotify.com/embed/artist/4dJ9EnUYna17QoVpH6ObIK?utm_source=generator"
            width="100%"
            height="450"
            frameborder="0"
            allowfullscreen=""
            allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
            loading="lazy"></iframe>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Divider -->
<div class="border-t border-brand-white/10 mx-4 md:mx-12"></div>

<!-- Tech rider download -->
<section class="relative py-24 px-4 md:px-12">
  <div
    class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-8"
  >
    <div>
      <h2 class="text-brand-white text-6xl md:text-8xl leading-none">
        TECH RIDER
      </h2>
      <span class="text-brand-accent font-display text-sm tracking-[0.4em]"
        >TECHNICAL INFORMATION</span
      >
    </div>
    <a
      href="/tech-rider.pdf"
      download
      class="group flex items-center gap-4 px-10 py-5 border border-brand-white/20 hover:border-brand-accent hover:bg-brand-accent transition-all duration-300"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        fill="currentColor"
        viewBox="0 0 256 256"
        class="text-brand-white group-hover:text-brand-black transition-colors duration-300"
      >
        <path
          d="M224,144v64a8,8,0,0,1-8,8H40a8,8,0,0,1-8-8V144a8,8,0,0,1,16,0v56H208V144a8,8,0,0,1,16,0Zm-101.66,5.66a8,8,0,0,0,11.32,0l40-40a8,8,0,0,0-11.32-11.32L136,124.69V32a8,8,0,0,0-16,0v92.69L93.66,98.34a8,8,0,0,0-11.32,11.32Z"
        ></path>
      </svg>
      <span
        class="font-display text-xl tracking-[0.2em] text-brand-white group-hover:text-brand-black transition-colors duration-300"
        >DOWNLOAD PDF</span
      >
    </a>
  </div>
</section>

<!-- Divider -->
<div class="border-t border-brand-white/10 mx-4 md:mx-12"></div>

<!-- Contact -->
<section class="relative py-32 px-4 md:px-12">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-end gap-8">
      <div>
        <h2 class="text-brand-white text-6xl md:text-8xl leading-none">
          CONTACT
        </h2>
        <span class="text-brand-accent font-display text-sm tracking-[0.4em]"
          >BOOKING & PRESS</span
        >
      </div>
      <div class="flex flex-col gap-4">
        <a
          href="https://www.instagram.com/tonguepunchmusic/"
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-4 text-brand-white/60 hover:text-brand-accent transition-colors duration-300"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 256 256" class="shrink-0">
            <path d="M128,80a48,48,0,1,0,48,48A48.05,48.05,0,0,0,128,80Zm0,80a32,32,0,1,1,32-32A32,32,0,0,1,128,160ZM176,24H80A56.06,56.06,0,0,0,24,80v96a56.06,56.06,0,0,0,56,56h96a56.06,56.06,0,0,0,56-56V80A56.06,56.06,0,0,0,176,24Zm40,152a40,40,0,0,1-40,40H80a40,40,0,0,1-40-40V80A40,40,0,0,1,80,40h96a40,40,0,0,1,40,40ZM192,76a12,12,0,1,1-12-12A12,12,0,0,1,192,76Z"/>
          </svg>
          <span class="font-display text-sm tracking-[0.2em]">@TONGUEPUNCHMUSIC</span>
        </a>
        <a
          href="mailto:tonguepunchmusicband@gmail.com"
          class="group flex items-center gap-4 text-brand-white/60 hover:text-brand-accent transition-colors duration-300"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 256 256" class="shrink-0">
            <path d="M224,48H32a8,8,0,0,0-8,8V192a16,16,0,0,0,16,16H216a16,16,0,0,0,16-16V56A8,8,0,0,0,224,48Zm-96,85.15L52.57,64H203.43ZM98.71,128,40,181.81V74.19Zm11.84,10.85,12,11.05a8,8,0,0,0,10.82,0l12-11.05,58,53.15H52.57ZM157.29,128,216,74.19V181.81Z"/>
          </svg>
          <span class="font-display text-sm tracking-[0.2em]">TONGUEPUNCHMUSICBAND@GMAIL.COM</span>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Footer strip -->
<div
  class="border-t border-brand-white/10 mx-4 md:mx-12 pb-12 pt-8 flex justify-between items-center px-4 md:px-12"
>
  <span class="font-display text-brand-white/20 text-sm tracking-widest"
    >TONGUE PUNCH © 2026</span
  >
  <a
    href="/"
    class="font-display text-sm tracking-[0.3em] text-brand-white/40 hover:text-brand-accent transition-colors"
    >← BACK TO SITE</a
  >
</div>

<style>
  @keyframes scroll-text {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
  .animate-scroll-text {
    animation: scroll-text 40s linear infinite;
  }
</style>
